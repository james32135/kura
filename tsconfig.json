{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "declaration": true
  },
  "include": [
    "hardhat.config.ts",
    "tasks/**/*.ts",
    "test/**/*.ts",
    "typechain-types/**/*.ts"
  ],
  "files": ["hardhat.config.ts"]
}
